// ─────────────────────────────────────────────────────────────────────────────
// Weather Station — ESP32-2432S028 (CYD)  ·  "Cyber Lime" Edition v5.14
//
// Changes vs v5.13:
//   [IMP 7]  getComfortLevel() return type changed from String to const char*.
//            All four return values are string literals residing in flash.
//            Returning String allocated a heap copy every call; const char*
//            returns the literal pointer directly — zero allocation.  Called
//            twice per second (dashboard + graph), so this eliminates 2 heap
//            alloc/free cycles per second permanently.
//   [IMP 8]  All remaining String objects in drawing functions converted to
//            snprintf() into stack-allocated char buffers.  Affected sites:
//              drawDashboardStatic() — ALT label
//              drawDashboardDynamic() — comfort, unitStr, tStr (temperature
//                number), dew point string, humidity string, pressure string
//              drawGraphStatic() — title string
//              drawGraphContent() — Y-axis scale labels, MAX/MIN stat strings
//              drawGraphDynamic() — comfort, NOW: reading string
//            After this change the sketch makes zero heap String allocations
//            during normal display operation.
//   [IMP 9]  UNIT= parser simplified to a direct character check.
//            Previously: String unit = cmd.substring(5); useCelsius=(unit=="C")
//            — allocated a one-character String on the heap.
//            Now: useCelsius = (cmd[5] == 'C') — no allocation, no object.
//   [IMP 10] NaN validation added to the setup() pre-fill block.
//            bme.readTemperature() / bme.readPressure() called immediately
//            after bme.begin() could return NaN on marginal I2C hardware.
//            Previously this silently filled all 96 history slots and both
//            cached extremes with NaN, corrupting the graph until reboot.
//            Fix: validated values fall back to sensible defaults (25 C,
//            1013.25 hPa sea-level standard) if either reading is NaN.
//
// Changes vs v5.12:
//   [IMP 1]  Brightness rounding corrected in setBrightness() and setup().
//            Formula changed from (pct * 255) / 100 to (pct * 255 + 50) / 100.
//            Adds 0.5 before truncation, giving proper rounding at all values
//            (e.g. 50% → 128 not 127, 75% → 191 correct).
//   [IMP 2]  Sensor validation added to main loop tick.
//            isnan() checks on rawC, hum, and rawP_hPa detect I2C glitches or
//            transient BME280 dropouts.  Any NaN skips the entire draw/accumulate
//            cycle silently: latestTempC/latestHum/latestInHg are not updated,
//            pressureStack is not corrupted, and no garbage appears on screen.
//            The 1-second timing cadence (lastTick) is preserved across skips.
//   [IMP 3]  Sensor error recovery added to setup().
//            Instead of a permanent while(1) halt, the sketch now makes up to
//            5 reinitialisation attempts at 1-second intervals, feeding the
//            watchdog between each attempt.  If all 5 fail, "RESTARTING..." is
//            shown and esp_restart() triggers a clean reboot.  The attempt
//            count is shown on screen so the user can see progress.
//   [IMP 4]  Confirmation overlay converted from String to char[32] buffer.
//            confirmMsg changed from String to char[32]; showConfirm() changed
//            to accept const char*.  ALT=, INT=, and BRT= handlers now use
//            snprintf() into local char buffers instead of String concatenation,
//            eliminating heap fragmentation from transient String objects.
//   [IMP 5]  Min/max pressure cached as globals (cachedMinP, cachedMaxP).
//            Previously drawGraphContent() scanned all 96 history slots every
//            graph redraw.  Cached values are now updated once per slot commit
//            in loop(), so drawGraphContent() reads two floats instead of
//            running an O(96) loop.
//   [IMP 6]  Serial STATUS header/footer reformatted with box-drawing characters
//            matching the rest of the file's comment style.
//
// Changes vs v5.11:
//   [FIX 13] Upper clamp added to INT= serial command.
//            Previously only the lower bound (1 min) was enforced.  Sending
//            INT=9999 produced a ~7-day slot interval, a nonsensical
//            "15930-HR TREND" title, and a graphInterval value close to the
//            signed long maximum.  New upper bound: 480 min (8 hr per slot ×
//            96 slots = 32-day maximum window).  Values above 480 are silently
//            clamped to 480 and the confirm overlay shows the clamped value.
//   [FIX 14] ALT label moved from drawDashboardDynamic() to drawDashboardStatic().
//            The label ("ALT: Xm") only changes when an ALT= serial command is
//            received, which already sets needsStaticRedraw = true.  Drawing and
//            erasing it every second inside the dynamic function was wasted SPI
//            work.  Moved to static with zero visual difference.
//   [FIX 15] COL_AMBER comment typo corrected in THEME 9 history block.
//            Line read: "Superseded by COL_LIME (data) / (Y-axis scale labels)"
//            — COL_ACCENT was missing after the slash.
//   [FIX 16] Sensor-error halt no longer triggers the hardware watchdog.
//            Previously when bme.begin() failed, the sketch entered while(1)
//            without feeding the watchdog.  After 10 s the watchdog rebooted
//            the board, causing a continuous reboot loop with the error message
//            visible only briefly.  Fix: esp_task_wdt_reset() is now called
//            inside the while(1) so the error message stays on screen until
//            power is cycled or the sensor is reconnected.
//   [FIX 17] INT= handler now resets lastReading to 0 so the new interval
//            takes effect on the very next tick.  Previously lastReading was
//            left at its old value, meaning the first new-interval slot could
//            be delayed by up to the full new interval duration.
//   [FIX 18] graphInterval changed from long to unsigned long.
//            It is always positive, is compared against unsigned long timing
//            values throughout, and was explicitly cast to unsigned long in the
//            history-commit check.  Using unsigned long from the start matches
//            the type of all other timing variables and removes the cast.
//
// Changes vs v5.10:
//   [FIX 12] Bottom of temperature number no longer cut off each second.
//            Root cause: in drawDashboardDynamic() the temperature number
//            (font 7, MC_DATUM at y=65, 48px tall) occupies y=41-89.  The
//            comfort label erase rect started at y=86 and the dew point erase
//            rect at y=88 — both inside the temperature text bottom (y=89).
//            Every second those rects repainted COL_PANEL over the bottom
//            1-3 pixel rows of the digits immediately after they were drawn.
//            Fix: both erase rects now start at y=90 (one pixel below the
//            temperature text bottom), leaving the number fully intact.
//            Comfort text (BL_DATUM y=105, font 2 16px) starts at y=90 — it
//            fits exactly within the adjusted rect with 2px bottom clearance.
//            No layout positions, font sizes, or panel dimensions changed.
//
// Changes vs v5.9b:
//   [CLEAN 1] COL_WHITE removed — it was defined but never referenced anywhere
//             in the code.  The palette comment incorrectly stated it was used
//             for sensor-error text; the actual sensor-error draw uses COL_RED.
//             Removed the #define and corrected the palette table comment.
//   [CLEAN 2] Section separator comment bar restored above handleSerialCommands().
//             It was accidentally dropped when setBrightness() was inserted
//             above it in v5.9.
//   [CLEAN 3] Redundant pinMode(TFT_BL_PIN, OUTPUT) removed from setup().
//             The core v3.x ledcAttach() call configures the pin itself;
//             the preceding pinMode was a no-op.
//
// Changes vs v5.9a:
//   [FIX 11] Boot safeguard for NVS brightness value.
//            If BRT=0 is sent, it is saved to NVS correctly and takes effect
//            immediately (screen goes dark).  On the next power cycle the sketch
//            reads brightness=0 from NVS and the display appears completely blank
//            — indistinguishable from a dead board.  Fix: after reading the NVS
//            brightness value, clamp any value below 10 % back to BL_DEFAULT_PCT
//            (75 %) before applying it.  BRT=0 still works in the running sketch
//            (useful for testing) but can no longer permanently blind the display.
//
// Changes vs v5.9a (= v5.8 + v5.9 + FIX 10):
//   [FIX 10] LEDC backlight init moved to AFTER tft.init() / tft.fillScreen().
//            TFT_eSPI internally calls digitalWrite(TFT_BL, HIGH) during
//            tft.init(), which reclaims pin 21 as a plain GPIO and silently
//            destroys any LEDC channel configured before it.  Result: display
//            stuck at full brightness regardless of BRT= commands.
//            Fix: ledcAttach() + ledcWrite() now execute after the entire TFT
//            init block (init, setRotation, invertDisplay, fillScreen), so LEDC
//            always gets the last word on the pin.
//
// Changes vs v5.8:
//   [PWM]  Backlight brightness now controlled via LEDC PWM instead of a plain
//          digitalWrite(HIGH).  Uses the ESP32 Arduino core v3.x single-argument
//          ledcAttach() / ledcWrite() API (no channel number required).
//          8-bit resolution (0-255), 5 kHz carrier — above audible range and
//          well within the CYD backlight driver's rated frequency.
//          Brightness is NVS-persisted so it survives power cycles.
//          Default: 75 % (duty 191/255).  Adjustable at runtime via BRT= command.
//          A setBrightness(pct) helper clamps input to 0-100, converts to duty,
//          writes to LEDC, and saves to NVS.
//          BRT= is added to the STATUS report alongside the other settings.
//
// Changes vs v5.7:
//   [THEME 9]  Complete palette overhaul — "Cyber Lime".
//
//   Research basis:
//     Human photoreceptors peak sensitivity at ~555 nm (yellow-green), making
//     electric lime the highest-legibility colour for data on a dark background.
//     TN panels like the CYD's suffer from backlight bleed that makes pure black
//     appear slightly grey.  Replacing 0x0000 with deep navy conceals this and
//     makes all foreground colours appear richer.  Violet is the direct
//     complementary colour to yellow-green on the colour wheel; using it for
//     borders and labels creates a split-complementary scheme that reads as
//     professional and high-contrast rather than garish.
//
//   COL_BG     0x0863  Deep navy #0B0F1A — screen fill, panel gaps.
//                      RGB(8,12,24).  Replaces COL_BLACK (0x0000).
//   COL_PANEL  0x2947  Deep violet-slate #2A283A — panel fill.
//                      RGB(41,40,57).  Slight violet bias ties the panel surface
//                      to the violet accent.  Replaces 0x31A7.
//   COL_ACCENT 0x7AFF  Soft violet #7D5FFF — panel borders, fixed labels,
//                      graph border/title/line, "Trend" label, breathing dot
//                      trough, Y-axis scale labels, confirm overlay fill.
//                      RGB(123,93,255).  Replaces amber-gold (0xDD05).
//   COL_LIME   0xC7E5  Electric lime #C7FF2E — ALL sensor data values
//                      (temperature, humidity, baro, dew point, NOW: reading,
//                      COLLECTING DATA...), up-trend arrow, flat-trend bar,
//                      breathing dot peak, confirm overlay text.
//                      RGB(198,255,41).  NEW — replaces COL_WHITE and COL_AMBER
//                      in every data-display role.
//   COL_WHITE  —       Removed in v5.10.  Was 0xFFFF; defined but never used
//                      in code (sensor-error draw uses COL_RED).
//   COL_AMBER  —       Removed in v5.8.  Superseded by COL_LIME (data) /
//                      COL_ACCENT (Y-axis scale labels).
//   COL_SHADE  0x10A4  Dark violet-shadow #16142C — graph area fill.
//                      RGB(16,20,33).  Replaces 0x18E4.
//   COL_GRID   0x318A  Violet-tinted grid lines #373050.
//                      RGB(49,48,82).  Replaces 0x4206.
//
//   Comfort semantic colours are intentionally unchanged — their warm-to-cool
//   gradient (cyan / green / orange / red) carries well-established meaning:
//     COL_CYAN   0x07FF  DRY
//     COL_GREEN  0x07E0  COMFORTABLE
//     COL_ORANGE 0xFD20  HUMID
//     COL_RED    0xF800  OPPRESSIVE / down-trend / MIN label
//
//   Confirm overlay redesigned: soft-violet fill, deep-navy border,
//   electric-lime text.  Previously: amber fill, black border, black text.
//
// All fixes and improvements from v5.0 – v5.7 are preserved.
//
// Barometric calibration note:
//   Use ALT= to fine-tune against a local reference (e.g. airport METAR).
//   A residual +-0.03 inHg offset is within the BME280 factory tolerance.
//
// Serial commands (115200 baud, newline-terminated, case-insensitive):
//   ALT=52      Set altitude to 52 m, save to NVS
//   INT=15      Set history slot interval to 15 min, save to NVS
//   UNIT=C      Switch display to Celsius, save to NVS
//   UNIT=F      Switch display to Fahrenheit, save to NVS
//   BRT=75      Set backlight brightness to 75 % (0-100), save to NVS
//   STATUS      Print current settings and live sensor readings
// ─────────────────────────────────────────────────────────────────────────────

#include <Wire.h>
#include <TFT_eSPI.h>
#include <Adafruit_BME280.h>
#include <Preferences.h>
#include <WiFi.h>
#include <math.h>
#include <esp_task_wdt.h>

// Watchdog timeout — auto-reboots if the main loop stalls (e.g. I2C lockup).
// Uses esp_task_wdt_config_t struct API (Arduino ESP32 core v3.x).
#define WDT_TIMEOUT_SEC  10

TFT_eSPI    tft = TFT_eSPI();
TFT_eSprite dotSprite(&tft);    // [FIX 3] 20x20 sprite for flicker-free breathing dot
Adafruit_BME280 bme;
Preferences     prefs;

// ── Board Selection ──────────────────────────────────────────────────────────
// Some ESP32-2432S028 (CYD) units ship with an inverted display panel.
// Set to true for the inverted board, false for the normal board.
// This is resolved at compile time — zero runtime cost.
#define INVERT_DISPLAY  true

// ── Hardware ─────────────────────────────────────────────────────────────────
#define TFT_BL_PIN   21
#define I2C_SDA      27
#define I2C_SCL      22
#define BME280_ADDR  0x76

// ── Backlight PWM ─────────────────────────────────────────────────────────────
// Core v3.x API: ledcAttach(pin, freq, resolution) / ledcWrite(pin, duty).
// 8-bit resolution → duty range 0-255.  5 kHz is above audible range and well
// within the CYD backlight driver's rated frequency.
#define BL_PWM_FREQ      5000   // Hz
#define BL_PWM_RES          8   // bits (0-255 duty range)
#define BL_DEFAULT_PCT     75   // % brightness on first boot (no NVS value yet)

// ── Color Palette — "Cyber Lime" ─────────────────────────────────────────────
//
//  COL_BG      0x0863  Deep navy #0B0F1A — screen fill and panel gaps   [was 0x0000]
//                      RGB(8,12,24) — masks TN backlight bleed
//  COL_PANEL   0x2947  Deep violet-slate #2A283A — panel fill            [was 0x31A7]
//                      RGB(41,40,57)
//  COL_ACCENT  0x7AFF  Soft violet #7D5FFF — borders, fixed labels,      [was 0xDD05]
//                      graph border/title/line, "Trend" label,
//                      breathing dot trough, Y-axis scale labels,
//                      confirm overlay fill.  RGB(123,93,255)
//  COL_LIME    0xC7E5  Electric lime #C7FF2E — ALL sensor data values,   [NEW]
//                      up-trend arrow, flat-trend bar, dot peak,
//                      confirm overlay text.  RGB(198,255,41)
//  COL_CYAN    0x07FF  DRY comfort level                                  [unchanged]
//  COL_RED     0xF800  OPPRESSIVE comfort, down-trend arrow, MIN label,   [unchanged]
//                      sensor-error text in setup()
//  COL_GREEN   0x07E0  COMFORTABLE comfort level only                     [unchanged]
//  COL_ORANGE  0xFD20  HUMID comfort level, MAX label                     [unchanged]
//  COL_SHADE   0x10A4  Dark violet-shadow — graph area fill               [was 0x18E4]
//                      RGB(16,20,33)
//  COL_GRID    0x318A  Violet-tinted grid lines                           [was 0x4206]
//                      RGB(49,48,82)
//
#define COL_BG       0x0863   // [THEME 9] deep navy screen background / gaps
#define COL_PANEL    0x2947   // [THEME 9] deep violet-slate panel fill
#define COL_ACCENT   0x7AFF   // [THEME 9] soft violet — borders, labels, graph
#define COL_LIME     0xC7E5   // [THEME 9] electric lime — all sensor data values
#define COL_CYAN     0x07FF   // DRY comfort level (unchanged)
#define COL_RED      0xF800   // OPPRESSIVE / down-trend / MIN / sensor-error (unchanged)
#define COL_GREEN    0x07E0   // COMFORTABLE comfort level only (unchanged)
#define COL_ORANGE   0xFD20   // HUMID comfort level / MAX label (unchanged)
#define COL_SHADE    0x10A4   // [THEME 9] dark violet-shadow graph area fill
#define COL_GRID     0x318A   // [THEME 9] violet-tinted grid lines

// ── NVS-Persisted Settings ───────────────────────────────────────────────────
float         userAltitude;    // metres above sea level
unsigned long graphInterval;   // milliseconds between history slots (always positive)
bool          useCelsius;      // true = C display, false = F display
int           userBrightness;  // backlight level 0-100 %

// ── Sensor History ───────────────────────────────────────────────────────────
const int   HISTORY_SIZE = 96;
float       pressureHistory[HISTORY_SIZE] = {0};
int         historyIndex = 0;
bool        historyFull  = false;

// ── Cached Graph Extremes ─────────────────────────────────────────────────────
// [IMP 5] Updated once per slot commit in loop() — eliminates O(96) scan from
// drawGraphContent() on every graph redraw.
float cachedMinP = 9999.0f;
float cachedMaxP =    0.0f;

// ── Timing ───────────────────────────────────────────────────────────────────
unsigned long lastReading = 0;
unsigned long modeTimer   = 0;   // initialized to millis() in setup() [FIX 9]
unsigned long lastTick    = 0;
int           currentMode = 0;

// ── Moving Average (double avoids float precision loss at ~450 samples/slot) ─
double pressureStack = 0.0;
int    sampleCount   = 0;

// ── Cached Live Readings (for STATUS command) ────────────────────────────────
float latestTempC = 0;
float latestHum   = 0;
float latestInHg  = 0;

// ── Confirmation Overlay ─────────────────────────────────────────────────────
char          confirmMsg[32] = "";   // [IMP 4] fixed buffer — no heap fragmentation
unsigned long confirmUntil   = 0;
bool          confirmActive  = false;

// ── Anti-Flicker State ────────────────────────────────────────────────────────
// needsStaticRedraw: set on mode change, serial command, or confirm-overlay clear.
//                    Triggers a full static panel redraw on the next tick.
// needsGraphRedraw : set whenever a new pressure slot is committed to history,
//                    or when needsStaticRedraw fires on the graph screen.
//                    Triggers a graph-content redraw on the next tick.
bool needsStaticRedraw = true;   // [FIX 1/4/5]
bool needsGraphRedraw  = true;   // [FIX 4]

// ─────────────────────────────────────────────────────────────────────────────
// FORWARD DECLARATIONS
// ─────────────────────────────────────────────────────────────────────────────
void     drawDashboardStatic();
void     drawDashboardDynamic(float rawC, float h, float p);
void     drawGraphStatic();
void     drawGraphContent(float rawC, float hum);
void     drawGraphDynamic(float currentInHg, float rawC, float hum);
void     drawConfirmOverlay();
void     drawBreathingDot();
void     drawTrendArrow(float delta, int cx, int cy);
uint16_t getComfortColor(float dewC);

// ─────────────────────────────────────────────────────────────────────────────
// CONFIRMATION OVERLAY HELPER
// [IMP 4] Accepts const char* — no String allocation on caller side.
// ─────────────────────────────────────────────────────────────────────────────
void showConfirm(const char* msg) {
  strncpy(confirmMsg, msg, sizeof(confirmMsg) - 1);
  confirmMsg[sizeof(confirmMsg) - 1] = '\0';   // guarantee null-termination
  confirmUntil  = millis() + 2000;
  confirmActive = true;
}

// ─────────────────────────────────────────────────────────────────────────────
// BRIGHTNESS HELPER
// Clamps pct to 0-100, converts to 8-bit duty, writes to LEDC, saves to NVS.
// ─────────────────────────────────────────────────────────────────────────────
void setBrightness(int pct) {
  if (pct < 0)   pct = 0;
  if (pct > 100) pct = 100;
  userBrightness = pct;
  uint8_t duty = (uint8_t)((pct * 255 + 50) / 100);  // [IMP 1] +50 for correct rounding
  ledcWrite(TFT_BL_PIN, duty);
  prefs.putInt("brightness", userBrightness);
}

// ─────────────────────────────────────────────────────────────────────────────
// SERIAL COMMAND PARSER
// ─────────────────────────────────────────────────────────────────────────────
void handleSerialCommands() {
  if (!Serial.available()) return;

  String cmd = Serial.readStringUntil('\n');
  cmd.trim();
  cmd.toUpperCase();

  if (cmd.startsWith("ALT=")) {
    float alt = cmd.substring(4).toFloat();
    if (alt < -500.0f) alt = -500.0f;    // [FIX 6] clamp to valid Earth range
    if (alt >  8849.0f) alt = 8849.0f;
    userAltitude = alt;
    prefs.putFloat("altitude", userAltitude);
    Serial.printf(">> ALTITUDE UPDATED: %.1f m\n", userAltitude);
    char buf[24];
    snprintf(buf, sizeof(buf), "ALT=%dm  OK", (int)userAltitude);  // [IMP 4]
    showConfirm(buf);
    needsStaticRedraw = true;
  }
  else if (cmd.startsWith("INT=")) {
    int mins = cmd.substring(4).toInt();
    if (mins < 1)   mins = 1;    // lower bound: 1 min per slot
    if (mins > 480) mins = 480;  // [FIX 13] upper bound: 480 min/slot = 32-day window
    graphInterval = (unsigned long)mins * 60000UL;
    prefs.putLong("interval", (long)graphInterval);
    pressureStack = 0.0;
    sampleCount   = 0;
    lastReading   = 0;           // [FIX 17] force immediate slot commit on next tick
    Serial.printf(">> INTERVAL UPDATED: %d min\n", mins);
    char buf[24];
    snprintf(buf, sizeof(buf), "INT=%dmin  OK", mins);  // [IMP 4]
    showConfirm(buf);
    needsStaticRedraw = true;
    needsGraphRedraw  = true;
  }
  else if (cmd.startsWith("UNIT=")) {
    // [IMP 9] Direct character check — no String allocation for a single char.
    useCelsius = (cmd[5] == 'C');
    prefs.putBool("celsius", useCelsius);
    Serial.printf(">> UNIT UPDATED: %s\n", useCelsius ? "Celsius" : "Fahrenheit");
    showConfirm(useCelsius ? "UNIT = C  OK" : "UNIT = F  OK");
    needsStaticRedraw = true;
  }
  else if (cmd.startsWith("BRT=")) {
    int pct = cmd.substring(4).toInt();
    setBrightness(pct);
    Serial.printf(">> BRIGHTNESS UPDATED: %d %%\n", userBrightness);
    char buf[24];
    snprintf(buf, sizeof(buf), "BRT=%d%%  OK", userBrightness);  // [IMP 4]
    showConfirm(buf);
  }
  else if (cmd == "STATUS") {
    int totalHours = (int)(((long long)graphInterval * HISTORY_SIZE) / 3600000LL);
    Serial.println("── STATUS ──────────────────────────────────────────");
    Serial.printf("  Altitude   : %.1f m\n",   userAltitude);
    Serial.printf("  Interval   : %lu min  (%d-hr window)\n",
                  graphInterval / 60000UL, totalHours);
    Serial.printf("  Unit       : %s\n",        useCelsius ? "Celsius" : "Fahrenheit");
    Serial.printf("  Brightness : %d %%\n",     userBrightness);
    Serial.printf("  Buffer     : %s  (%d / %d slots)\n",
                  historyFull ? "FULL" : "FILLING",
                  historyFull ? HISTORY_SIZE : historyIndex, HISTORY_SIZE);
    Serial.printf("  Temp       : %.1f C\n",    latestTempC);
    Serial.printf("  Humidity   : %.1f %%\n",   latestHum);
    Serial.printf("  Pressure   : %.2f inHg\n", latestInHg);
    Serial.println("────────────────────────────────────────────────────");
  }
}

// ── Environmental Math ───────────────────────────────────────────────────────

float calculateDewPointC(float tempC, float humidity) {
  float a = 17.271f, b = 237.7f;
  float alpha = ((a * tempC) / (b + tempC)) + log(humidity / 100.0f);
  return (b * alpha) / (a - alpha);
}

// [IMP 7] Returns const char* — literal pointer into flash, zero heap allocation.
const char* getComfortLevel(float dewC) {
  if (dewC < 10.0f)  return "DRY";
  if (dewC < 15.6f)  return "COMFORTABLE";
  if (dewC < 21.1f)  return "HUMID";
  return "OPPRESSIVE";
}

// ─────────────────────────────────────────────────────────────────────────────
// COMFORT COLOR
// Semantic colours kept intentionally from the original design — their
// warm-to-cool gradient is immediately understood at a glance:
//   DRY         -> cyan   (cool, refreshing)
//   COMFORTABLE -> green  (pleasant)
//   HUMID       -> orange (warm, sticky)
//   OPPRESSIVE  -> red    (hot, uncomfortable)
// ─────────────────────────────────────────────────────────────────────────────
uint16_t getComfortColor(float dewC) {
  if (dewC < 10.0f)  return COL_CYAN;
  if (dewC < 15.6f)  return COL_GREEN;
  if (dewC < 21.1f)  return COL_ORANGE;
  return COL_RED;
}

float toDisplay(float tempC) {
  return useCelsius ? tempC : (tempC * 1.8f) + 32.0f;
}

// ─────────────────────────────────────────────────────────────────────────────
// BREATHING DOT  [FIX 3]
// Rendered into a 20x20 TFT_eSprite. The sprite is filled with COL_PANEL
// to erase the previous circle, then the new circle is drawn and pushed as
// one SPI burst — no flicker.
// Sprite top-left: (276, 18) -> circle centre at (286, 28).
// [THEME 9] Peak: COL_LIME (electric lime). Trough: COL_ACCENT (soft violet).
//           The pulse cycles through the two palette primaries — a live
//           heartbeat that reinforces the Cyber Lime aesthetic.
// ─────────────────────────────────────────────────────────────────────────────
void drawBreathingDot() {
  float    phase     = (float)(millis() % 4000) / 4000.0f;
  float    breathVal = (sinf(phase * 2.0f * PI) + 1.0f) / 2.0f;
  int      r         = 3 + (int)(breathVal * 5.0f);
  uint16_t col       = (breathVal > 0.5f) ? COL_LIME : COL_ACCENT; // [THEME 9]

  dotSprite.fillSprite(COL_PANEL);       // erase with panel color
  dotSprite.fillCircle(10, 10, r, col);  // draw new circle
  dotSprite.pushSprite(276, 18);         // push as single SPI burst
}

// ─────────────────────────────────────────────────────────────────────────────
// TREND ARROW
// [THEME 9] Up arrow: COL_LIME — rising pressure is a positive reading,
//                                matching the lime data colour.
//           Down arrow: COL_RED — falling pressure, warning colour.
//           Flat bar:   COL_LIME — neutral, consistent with data colour.
// ─────────────────────────────────────────────────────────────────────────────
void drawTrendArrow(float delta, int cx, int cy) {
  const int hw = 8, hh = 7;
  if (delta > 0.005f)
    tft.fillTriangle(cx, cy-hh, cx-hw, cy+hh, cx+hw, cy+hh, COL_LIME);  // [THEME 9]
  else if (delta < -0.005f)
    tft.fillTriangle(cx, cy+hh, cx-hw, cy-hh, cx+hw, cy-hh, COL_RED);
  else
    tft.fillRect(cx-hw, cy-3, hw*2, 6, COL_LIME);                        // [THEME 9]
}

