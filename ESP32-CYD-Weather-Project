           (int)round(dispDew), unitStr);
  tft.drawString(dewBuf, 295, 105, 2);

  // ── Humidity value ─────────────────────────────────────────────────────────
  // Font 4 TC_DATUM at y=185 -> bottom ~y=211. Height 67 -> covers to y=225.
  tft.fillRect(14, 158, 133, 67, COL_PANEL);
  tft.setTextColor(COL_LIME, COL_PANEL);                 // [THEME 9] lime data
  tft.setTextDatum(TC_DATUM);
  char humBuf[8];
  snprintf(humBuf, sizeof(humBuf), "%d%%", (int)round(h));  // [IMP 8]
