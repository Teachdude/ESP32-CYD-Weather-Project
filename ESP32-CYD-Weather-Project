// ─────────────────────────────────────────────────────────────────────────────
// SETUP
// ─────────────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_OFF);

  // Hardware watchdog — core v3.x struct API
  const esp_task_wdt_config_t wdt_config = {
    .timeout_ms     = WDT_TIMEOUT_SEC * 1000,
    .idle_core_mask = 0,
    .trigger_panic  = true
  };
  esp_task_wdt_init(&wdt_config);
  esp_task_wdt_add(NULL);

  prefs.begin("weather-stat", false);
  userAltitude   = prefs.getFloat("altitude",   100.0f);
  graphInterval  = (unsigned long)prefs.getLong("interval", 450000L);
  useCelsius     = prefs.getBool ("celsius",    false);
  userBrightness = prefs.getInt  ("brightness", BL_DEFAULT_PCT);
  // [FIX 11] Clamp — a stored value below 10 % would make the display appear
  // completely blank on boot, indistinguishable from a hardware fault.
  if (userBrightness < 10) userBrightness = BL_DEFAULT_PCT;

  Serial.printf(">> BOOT -- Altitude: %.1f m | Interval: %.1f min | Unit: %s | Brightness: %d %%\n",
                userAltitude, graphInterval / 60000.0,
                useCelsius ? "Celsius" : "Fahrenheit",
                userBrightness);

  tft.init();
  tft.setRotation(1);
#if INVERT_DISPLAY
  tft.invertDisplay(true);
#else
  tft.invertDisplay(false);
#endif
  tft.fillScreen(COL_BG);                                // [THEME 9] deep navy fill

  // Backlight PWM — MUST be configured AFTER tft.init().
  // TFT_eSPI calls digitalWrite(TFT_BL, HIGH) inside init(), which reclaims
  // pin 21 as a plain GPIO and silently breaks any LEDC setup done before it.
  // By attaching LEDC here we always get the last word on the pin.
  // Core v3.x API: ledcAttach() configures the pin itself — no pinMode needed.
  ledcAttach(TFT_BL_PIN, BL_PWM_FREQ, BL_PWM_RES);
  ledcWrite(TFT_BL_PIN, (uint8_t)((userBrightness * 255 + 50) / 100));  // [IMP 1]

  // [FIX 3] Create breathing-dot sprite once; 800 bytes from internal SRAM.
  dotSprite.createSprite(20, 20);
  dotSprite.setColorDepth(16);

  Wire.begin(I2C_SDA, I2C_SCL);
  // [IMP 3] Up to 5 reinitialisation attempts before a clean reboot.
  // The watchdog is fed between attempts so it does not fire prematurely.
  {
    bool sensorFound = false;
    for (int attempt = 1; attempt <= 5 && !sensorFound; attempt++) {
      if (bme.begin(BME280_ADDR)) {
        sensorFound = true;
      } else {
        tft.setTextDatum(MC_DATUM);
        tft.setTextColor(COL_RED);
        tft.drawCentreString("SENSOR ERROR", 160, 100, 4);
        char retryBuf[28];
        snprintf(retryBuf, sizeof(retryBuf), "Retrying... (%d/5)", attempt);
        tft.setTextColor(COL_ACCENT);
        tft.drawCentreString(retryBuf, 160, 140, 2);
        esp_task_wdt_reset();
        delay(1000);
        // Clear retry line before next attempt overwrites it
        tft.fillRect(0, 128, 320, 30, COL_BG);
      }
    }
    if (!sensorFound) {
      tft.fillScreen(COL_BG);
      tft.setTextDatum(MC_DATUM);
      tft.setTextColor(COL_RED);
      tft.drawCentreString("SENSOR ERROR", 160, 100, 4);
      tft.setTextColor(COL_ACCENT);
      tft.drawCentreString("RESTARTING...", 160, 140, 2);
      delay(2000);
      esp_restart();
    }
  }

  // Pre-fill history with current altitude-corrected sea-level pressure.
  // [IMP 10] Validate readings — bme.read*() can return NaN on marginal I2C
  // hardware immediately after init.  Fall back to sensible defaults so the
  // history buffer and cached extremes are never seeded with NaN.
  float rawC = bme.readTemperature();
  float rawP = bme.readPressure() / 100.0f;
  if (isnan(rawC)) rawC = 25.0f;          // 25 C — safe indoor default
  if (isnan(rawP)) rawP = 1013.25f;       // ISA sea-level standard pressure
  float p_slp = rawP * pow(1.0f - (0.0065f * userAltitude / (rawC + 273.15f)), -5.257f);
  for (int i = 0; i < HISTORY_SIZE; i++) pressureHistory[i] = p_slp;
  cachedMinP = cachedMaxP = p_slp;   // [IMP 5] cache valid from boot

  latestTempC = rawC;
  latestHum   = bme.readHumidity();
  latestInHg  = p_slp * 0.02953f;

  modeTimer = millis();   // [FIX 9] start rotation timer from boot, not from 0
  needsStaticRedraw = true;
  needsGraphRedraw  = true;
}

// ─────────────────────────────────────────────────────────────────────────────
// MAIN LOOP
// ─────────────────────────────────────────────────────────────────────────────
void loop() {
  esp_task_wdt_reset();
  handleSerialCommands();

  unsigned long now = millis();

  // ── Screen rotation every 15 s ────────────────────────────────────────────
  if (now - modeTimer > 15000) {
    currentMode ^= 1;
    modeTimer = now;
    tft.fillScreen(COL_BG);                              // [THEME 9] deep navy fill
    needsStaticRedraw = true;
    needsGraphRedraw  = true;
  }

  // ── 1-second non-blocking tick ────────────────────────────────────────────
  if (now - lastTick >= 1000 || lastTick == 0) {
    lastTick = now;

    float rawC     = bme.readTemperature();
    float hum      = bme.readHumidity();
    float rawP_hPa = bme.readPressure() / 100.0f;

    // [IMP 2] Validate readings — I2C glitches or transient BME280 dropouts
    // return NaN.  Skip accumulation and drawing entirely; lastTick is already
    // updated so the 1-second cadence is preserved across skips.
    bool  sensorOk     = !isnan(rawC) && !isnan(hum) && !isnan(rawP_hPa);
    float inHg_instant = 0.0f;  // declared here so the draw block can see it

    if (sensorOk) {
      float p_hPa_instant = rawP_hPa * pow(1.0f - (0.0065f * userAltitude / (rawC + 273.15f)), -5.257f);
      inHg_instant = p_hPa_instant * 0.02953f;

      latestTempC = rawC;
      latestHum   = hum;
      latestInHg  = inHg_instant;

      pressureStack += (double)p_hPa_instant;
      sampleCount++;

      // Commit averaged pressure slot to history buffer
      if (now - lastReading > graphInterval || lastReading == 0) {
        float averagedP = (float)(pressureStack / sampleCount);
        pressureHistory[historyIndex] = averagedP;
        historyIndex = (historyIndex + 1) % HISTORY_SIZE;
        if (historyIndex == 0) historyFull = true;
        pressureStack = 0.0;
        sampleCount   = 0;
        lastReading   = now;
        needsGraphRedraw = true;

        // [IMP 5] Update cached min/max — eliminates O(96) scan in drawGraphContent().
        int cPts = historyFull ? HISTORY_SIZE : historyIndex;
        cachedMinP = 9999.0f;
        cachedMaxP =    0.0f;
        for (int i = 0; i < cPts; i++) {
          int idx = historyFull ? (historyIndex + i) % HISTORY_SIZE : i;
          if (pressureHistory[idx] < cachedMinP) cachedMinP = pressureHistory[idx];
          if (pressureHistory[idx] > cachedMaxP) cachedMaxP = pressureHistory[idx];
        }
      }
    }  // end sensorOk

    // Confirm overlay expiry — always checked regardless of sensor state
    if (confirmActive && now >= confirmUntil) {
      confirmActive = false;
      tft.fillScreen(COL_BG);
      needsStaticRedraw = true;
      needsGraphRedraw  = true;
    }

    // ── Draw — skipped entirely on bad sensor readings ────────────────────────
    if (sensorOk) {
      if (currentMode == 0) {
        // Dashboard
        if (needsStaticRedraw) {
          drawDashboardStatic();
          needsStaticRedraw = false;
        }
        drawDashboardDynamic(rawC, hum, inHg_instant);

      } else {
        // Graph screen
        if (needsStaticRedraw) {
          drawGraphStatic();
          needsStaticRedraw = false;
          needsGraphRedraw  = true;  // always redraw content after fresh static layer
        }
        if (needsGraphRedraw) {
          drawGraphContent(rawC, hum);
          needsGraphRedraw = false;
        }
        drawGraphDynamic(inHg_instant, rawC, hum);
      }
    }  // end sensorOk draw

    if (confirmActive) drawConfirmOverlay();
  }
}
