// ─────────────────────────────────────────────────────────────────────────────
// GRAPH — CONTENT  [FIX 4]
// Grid, plot, Y-axis labels, MAX/MIN stats.
// Called only when needsGraphRedraw is true (new history slot committed).
//
// [THEME 9] Data values (NOW, COLLECTING DATA) -> COL_LIME.
//           Y-axis scale labels -> COL_ACCENT (they are axis annotations,
//           not raw sensor values, so violet keeps them visually subordinate).
//           Graph line -> COL_ACCENT.  Area fill -> COL_SHADE.
//           Grid lines -> COL_GRID (violet-tinted).
// ─────────────────────────────────────────────────────────────────────────────
void drawGraphContent(float rawC, float hum) {
  const int gx = 45, gy = 50, gw = 260, gh = 110;
  int pts = historyFull ? HISTORY_SIZE : historyIndex;

  // Clear content area from safely below the title.
  // Font 2 MC_DATUM at y=18 -> bottom at y=26; start at y=31 (5 px clearance).
  tft.fillRect(6, 31, 308, 169, COL_PANEL);

  if (pts < 2) {
    tft.setTextColor(COL_LIME, COL_PANEL);               // [THEME 9] lime data
    tft.setTextDatum(MC_DATUM);
    tft.drawCentreString("COLLECTING DATA...", 160, 120, 2);
    float    dewC   = calculateDewPointC(rawC, hum);
    uint16_t comCol = getComfortColor(dewC);
    tft.setTextColor(comCol, COL_PANEL);
    tft.drawCentreString(getComfortLevel(dewC), 160, 212, 2);
    return;
  }

  // ── Min / max — use values cached at slot-commit time [IMP 5] ──────────────
  // cachedMinP/cachedMaxP are updated in loop() whenever a new slot is committed,
  // eliminating the O(96) scan that previously ran on every graph redraw.
  float minP  = cachedMinP;
  float maxP  = cachedMaxP;
  float range = maxP - minP;
  if (range < 1.0f) range = 1.0f;

  // ── Vertical grid lines ───────────────────────────────────────────────────
  for (int g = 0; g <= 12; g++) {
    int lx = gx + (g * gw / 12);
    tft.drawFastVLine(lx, gy, gh, COL_GRID);             // [THEME 9] violet grid
  }

  // ── Y-axis scale labels ───────────────────────────────────────────────────
  // [THEME 9] COL_AMBER -> COL_ACCENT: these are axis scale annotations
  // (not raw data readings), so violet keeps them visually subordinate to lime.
  tft.setTextDatum(TR_DATUM);
  tft.setTextColor(COL_ACCENT, COL_PANEL);               // [THEME 9] violet scale
  char yMax[10], yMin[10];
  snprintf(yMax, sizeof(yMax), "%.2f", maxP * 0.02953f); // [IMP 8]
  snprintf(yMin, sizeof(yMin), "%.2f", minP * 0.02953f); // [IMP 8]
  tft.drawString(yMax, gx - 2, gy,          1);
  tft.drawString(yMin, gx - 2, gy + gh - 6, 1);

  // ── Plot chronologically ──────────────────────────────────────────────────
  // Area fill: COL_SHADE (dark violet-shadow — subtly darker than the panel).
  // Data line: COL_ACCENT (soft violet) — a complementary contrast to lime.
  int divisor = pts - 1;
  for (int i = 0; i < pts - 1; i++) {
    int idxA = historyFull ? (historyIndex + i)     % HISTORY_SIZE : i;
    int idxB = historyFull ? (historyIndex + i + 1) % HISTORY_SIZE : i + 1;
    int x1 = gx + (i       * gw / divisor);
    int x2 = gx + ((i + 1) * gw / divisor);
    int y1 = (gy + gh) - (int)((pressureHistory[idxA] - minP) / range * gh);
    int y2 = (gy + gh) - (int)((pressureHistory[idxB] - minP) / range * gh);
    tft.drawFastVLine(x1, y1, (gy + gh) - y1, COL_SHADE); // [THEME 9] violet shadow
    tft.drawLine(x1, y1, x2, y2, COL_ACCENT);              // [THEME 9] violet line
  }

  // ── MAX / MIN stats (left side) ───────────────────────────────────────────
  tft.setTextDatum(TL_DATUM);
  char maxBuf[20], minBuf[20];
  snprintf(maxBuf, sizeof(maxBuf), "MAX: %.2f", maxP * 0.02953f);  // [IMP 8]
  snprintf(minBuf, sizeof(minBuf), "MIN: %.2f", minP * 0.02953f);  // [IMP 8]
  tft.setTextColor(COL_ORANGE, COL_PANEL);
  tft.drawString(maxBuf, 10, 168, 2);
  tft.setTextColor(COL_RED, COL_PANEL);
  tft.drawString(minBuf, 10, 186, 2);
}

// ─────────────────────────────────────────────────────────────────────────────
// GRAPH — DYNAMIC  [FIX 4]
// NOW reading, trend arrow, comfort label — updated every second.
// Each element is erased with a targeted fillRect() before redrawing.
// ─────────────────────────────────────────────────────────────────────────────
void drawGraphDynamic(float currentInHg, float rawC, float hum) {
  int pts = historyFull ? HISTORY_SIZE : historyIndex;
  if (pts < 2) return;   // drawGraphContent handles the collecting-data case

  int   oldestIdx = historyFull ? historyIndex : 0;
  int   newestIdx = (historyIndex - 1 + HISTORY_SIZE) % HISTORY_SIZE;
  float delta     = (pressureHistory[newestIdx] - pressureHistory[oldestIdx]) * 0.02953f;

  // ── NOW: reading ──────────────────────────────────────────────────────────
  tft.setTextDatum(TR_DATUM);
  tft.setTextColor(COL_LIME, COL_PANEL);                 // [THEME 9] lime data
  char nowBuf[16];
  snprintf(nowBuf, sizeof(nowBuf), "NOW: %.2f", currentInHg);  // [IMP 8]
  tft.drawString(nowBuf, 310, 168, 2);

  // ── "Trend" label ─────────────────────────────────────────────────────────
  tft.setTextColor(COL_ACCENT, COL_PANEL);               // [THEME 9] violet label
  tft.drawString("Trend", 262, 183, 2);

  // ── Trend arrow ───────────────────────────────────────────────────────────
  // Shape changes (up/down/flat) so previous triangle footprint must be cleared.
  tft.fillRect(274, 183, 18, 16, COL_PANEL);
  drawTrendArrow(delta, 282, 190);

  // ── Comfort label ─────────────────────────────────────────────────────────
  // Text width varies (DRY -> COMFORTABLE) so a fillRect clear is used.
  float       dewC    = calculateDewPointC(rawC, hum);
  const char* comfort = getComfortLevel(dewC);           // [IMP 7+8] no heap alloc
  uint16_t    comCol  = getComfortColor(dewC);
  tft.fillRect(55, 203, 210, 18, COL_PANEL);
  tft.setTextDatum(MC_DATUM);
  tft.setTextColor(comCol, COL_PANEL);
  tft.drawCentreString(comfort, 160, 212, 2);
}

