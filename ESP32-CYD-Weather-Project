  tft.drawString(unitStr, symX + 10, mainY - 14, 4);

  // ── Comfort label (bottom-left of temperature panel) ──────────────────────
  // Width 140 safely clears "COMFORTABLE" (~110 px in font 2).
  // [FIX 12] fillRect now starts at y=90 — one pixel below the temperature
  // text bottom (font 7 MC_DATUM y=65, 48px tall → bottom at y=89).
  // Previous start y=86 was erasing the bottom 3 rows of the temperature
  // number every second.  Comfort text (BL_DATUM y=105, font 2 16px) starts
  // at y=90 — fits within this rect with 2px bottom clearance to y=107.
  tft.fillRect(22, 90, 140, 18, COL_PANEL);
  tft.setTextDatum(BL_DATUM);
  tft.setTextColor(comCol, COL_PANEL);                   // semantic comfort colour
  tft.drawString(comfort, 25, 105, 2);

  // ── Dew point (bottom-right of temperature panel) ─────────────────────────
