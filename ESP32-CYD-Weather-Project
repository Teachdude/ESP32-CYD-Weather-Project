//
// FIX 8 — all setTextColor() calls use two-argument form with COL_PANEL.
//   Character-cell backgrounds are explicitly painted with the panel colour
//   on every draw, providing a second layer of ghost-pixel protection.
// ─────────────────────────────────────────────────────────────────────────────
void drawDashboardDynamic(float rawC, float h, float p) {
  float       dewC    = calculateDewPointC(rawC, h);
  const char* comfort = getComfortLevel(dewC);           // [IMP 7+8] no heap alloc
  uint16_t    comCol  = getComfortColor(dewC);
  float       dispTemp = toDisplay(rawC);
  float       dispDew  = toDisplay(dewC);
  const char* unitStr  = useCelsius ? "C" : "F";         // [IMP 8] literal pointer

  // ── Breathing dot ─────────────────────────────────────────────────────────
